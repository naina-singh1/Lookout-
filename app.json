{
  "expo": {
    "name": "Lookout",
    "slug": "Lookout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gopika.lookout",
      "config": {
        "googleMapsApiKey": "AIzaSyBvh6kAxCSP_5nU8JEi_f_urI_W4HlcYU4"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Lookout shows nearby potholes and alerts you when one is ahead.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Lookout alerts you about potholes even when the app is in the background while driving.",
        "NSLocationAlwaysUsageDescription": "Lookout needs background location to warn you about potholes while driving.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification",
          "location",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gopika.lookout",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBvh6kAxCSP_5nU8JEi_f_urI_W4HlcYU4"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#e85c3a"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lookout shows nearby potholes and alerts you when one is ahead.",
          "locationAlwaysAndWhenInUsePermission": "Lookout alerts you about potholes even when driving with the app in the background.",
          "locationAlwaysPermission": "Lookout needs background location to warn you about potholes while driving.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "51f4be6c-d802-4519-8352-4b6fe13de5dd"
      }
    },
    "owner": "nainasingh1"
  }
}
